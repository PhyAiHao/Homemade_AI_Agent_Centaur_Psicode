{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "tools/**/*.ts",
    "transports/**/*.ts",
    "bridge/**/*.ts",
    "mcp/**/*.ts",
    "lsp/**/*.ts",
    "chrome/**/*.ts",
    "sdk/**/*.ts",
    "auth/**/*.ts"
  ]
}
